{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strictNullChecks": true,

    "paths": {
      "@printdesk/core/*": ["../core/src/*"]
    },

    "plugins": [{ "name": "@effect/language-service" }]
  }
}
